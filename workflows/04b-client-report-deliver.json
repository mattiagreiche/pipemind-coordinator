    {
      "parameters": {
        "jsCode": "// Prepare delivery context \u2014 compute today's date for file naming\nconst trigger = $node['Execute Workflow Trigger'].json;\nconst today = new Date().toISOString().split('T')[0];\nconst accessToken = $input.first().json.access_token;\nreturn [{\n  json: {\n    draft_id: trigger.draft_id,\n    content_text: trigger.content_text,\n    access_token: accessToken,\n    today_iso: today,\n    file_name: `Client Report ${today}.txt`,\n    email_subject: `Project Update \u2014 ${today}`\n  }\n}];"
      },
      "id": "node-prepare-delivery-context",
      "name": "Prepare Delivery Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        980,
        500
