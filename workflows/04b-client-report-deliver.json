              "value": "=Bearer {{ $node['Prepare Delivery Context'].json.access_token }}"
            },
            {
              "name": "Content-Type",
              "value": "multipart/related; boundary=pipemind_boundary"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "multipart/related; boundary=pipemind_boundary",
        "body": "=--pipemind_boundary\r\nContent-Type: application/json; charset=UTF-8\r\n\r\n{\"name\": \"{{ $node['Prepare Delivery Context'].json.file_name }}\", \"parents\": [\"{{ $env.DRIVE_FOLDER_ID }}\"]}\r\n--pipemind_boundary\r\nContent-Type: text/plain; charset=UTF-8\r\n\r\n{{ $node['Prepare Delivery Context'].json.content_text }}\r\n--pipemind_boundary--",
        "options": {}
      },
