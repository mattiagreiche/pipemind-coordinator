            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-drive-exists",
              "leftValue": "={{ ($json.files || []).length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
