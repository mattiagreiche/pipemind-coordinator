    {
      "parameters": {
        "jsCode": "// Build RFC 2822 email encoded as base64 for Gmail API\nconst clientEmail = process.env.CLIENT_EMAIL;\nconst subject = $node['Prepare Delivery Context'].json.email_subject;\nconst body = $node['Prepare Delivery Context'].json.content_text;\nconst raw = `To: ${clientEmail}\\r\\nSubject: ${subject}\\r\\nContent-Type: text/plain; charset=UTF-8\\r\\n\\r\\n${body}`;\nconst encoded = Buffer.from(raw).toString('base64').replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/, '');\nreturn [{\n  json: {\n    raw: encoded,\n    access_token: $node['Prepare Delivery Context'].json.access_token,\n    draft_id: $node['Prepare Delivery Context'].json.draft_id,\n    today_iso: $node['Prepare Delivery Context'].json.today_iso\n  }\n}];"
      },
