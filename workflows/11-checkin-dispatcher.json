          "queryReplacement": "={{ [$json.discord_id] }}"
        },
        "options": {}
      },
      "id": "node-wf11-check-mute",
      "name": "Check Mute List",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2520,
        500
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
