{
  "name": "11 \u2014 Check-In Dispatcher (F-05)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 13 * * *"
            }
          ]
        }
      },
      "id": "node-wf11-cron",
      "name": "Cron Trigger \u2014 Daily Check-In",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Load roster \u2014 extract active team members with all schedule fields.\nconst fs = require('fs');\nconst yaml = require('js-yaml');\nconst path = process.env.ROSTER_CONFIG_PATH || '/data/roster.yml';\nlet roster;\ntry {\n  roster = yaml.load(fs.readFileSync(path, 'utf8'));\n} catch (e) {\n  throw new Error('Check-In Dispatcher: cannot load roster.yml: ' + e.message);\n}\nconst activeTeam = (roster.team || []).filter(m => m.active !== false);\nreturn [{\n  json: {\n    team: activeTeam,\n    team_lead_channel_id: roster.team_lead_channel_id\n  }\n}];"
      },
      "id": "node-wf11-load-roster",
      "name": "Load Roster",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Verify required env vars. Warn (non-fatal) if CHECKIN_TIME absent.\nconst required = ['DISCORD_BOT_TOKEN', 'CLOCKIFY_API_KEY', 'CLOCKIFY_WORKSPACE_ID', 'GOOGLE_CLIENT_ID', 'GOOGLE_CLIENT_SECRET', 'GOOGLE_REFRESH_TOKEN'];\nconst missing = required.filter(k => !process.env[k] || process.env[k].trim() === '');\nif (missing.length > 0) {\n  throw new Error('FATAL: Check-In Dispatcher missing required env vars: ' + missing.join(', '));\n}\nif (!process.env.CHECKIN_TIME || process.env.CHECKIN_TIME.trim() === '') {\n  console.warn('WARN: CHECKIN_TIME not set \u2014 defaulting to 13:00 UTC for check-in cron.');\n}\nreturn [{ json: $json }];"
      },
      "id": "node-wf11-check-env",
      "name": "Check Env Vars",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://oauth2.googleapis.com/token",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "client_id": "={{ $env.GOOGLE_CLIENT_ID }}",
          "client_secret": "={{ $env.GOOGLE_CLIENT_SECRET }}",
          "refresh_token": "={{ $env.GOOGLE_REFRESH_TOKEN }}",
          "grant_type": "refresh_token"
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "node-wf11-refresh-token",
      "name": "Refresh Google Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT value_json FROM project_memory WHERE key = 'standup_heard_' || to_char(now(), 'YYYY-MM-DD') LIMIT 1",
        "options": {}
      },
      "id": "node-wf11-read-heard",
      "name": "Read Today's Standup-Heard",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        980,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "Postgres \u2014 Coordination Agent"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Expand roster to individual items; attach heard_ids and access_token.\nconst rosterData = $node['Load Roster'].json;\nconst tokenResult = $node['Refresh Google Token'].json;\nconst heardRow = $node['Read Today\\'s Standup-Heard'].json;\n\nconst accessToken = (tokenResult && tokenResult.access_token) ? tokenResult.access_token : null;\nconst heardIds = (heardRow && heardRow.value_json)\n  ? (Array.isArray(heardRow.value_json) ? heardRow.value_json : [])\n  : [];\n\nreturn rosterData.team.map(m => ({\n  json: {\n    ...m,\n    team_lead_channel_id: rosterData.team_lead_channel_id,\n    heard_ids: heardIds,\n    access_token: accessToken,\n    today: new Date().toISOString().slice(0, 10)\n  }\n}));"
      },
      "id": "node-wf11-expand-roster",
      "name": "Expand Roster to Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        300
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "node-wf11-for-each-dev",
      "name": "For Each Developer",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1420,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Check if developer was already heard from in today's standup.\nconst heard = $json.heard_ids || [];\nconst discordId = $json.discord_id;\nconst today = $json.today;\nreturn [{ json: { ...$json, already_heard: heard.includes(discordId), today } }];"
      },
      "id": "node-wf11-check-heard",
      "name": "Check Already Heard From",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1640,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-wf11-heard",
              "leftValue": "={{ $json.already_heard }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-wf11-if-heard",
      "name": "IF Already Heard From",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1860,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT value_json FROM project_memory WHERE key = 'checkin_sent_' || $1 || '_' || $2 LIMIT 1",
        "additionalFields": {
          "queryBatching": "independently",
          "queryReplacement": "={{ [$json.today, $json.discord_id] }}"
        },
        "options": {}
      },
      "id": "node-wf11-check-idempotency",
      "name": "Check Idempotency \u2014 Already Sent Today",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
