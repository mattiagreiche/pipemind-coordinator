    {
      "parameters": {
        "jsCode": "// Extract DM channel ID from result.\nconst dmResult = $input.first().json;\nconst devData = $json;\nif (dmResult.error || !dmResult.id) {\n  return [{ json: { ...devData, dm_channel_id: null, dm_open_failed: true } }];\n}\nreturn [{ json: { ...devData, dm_channel_id: dmResult.id, dm_open_failed: false } }];"
