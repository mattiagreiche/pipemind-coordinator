    {
      "parameters": {
        "url": "=https://api.clockify.me/api/v1/workspaces/{{ $env.CLOCKIFY_WORKSPACE_ID }}/time-off/requests?status=APPROVED&start={{ $json.today }}T00:00:00Z&end={{ $json.today }}T23:59:59Z",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Api-Key",
              "value": "={{ $env.CLOCKIFY_API_KEY }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "node-wf11-check-clockify",
      "name": "Check Clockify Schedule",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2960,
        600
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Evaluate Clockify time-off result.\nconst result = $input.first().json;\nconst clockifyId = $json.clockify_id;\nlet clockify_available = true;\nlet on_leave_clockify = false;\n\nif (result.error || !Array.isArray(result)) {\n  clockify_available = false;\n} else {\n  on_leave_clockify = result.some(req => req.userId === clockifyId && req.status === 'APPROVED');\n}\nreturn [{ json: { ...$json, clockify_available, on_leave_clockify } }];"
      },
      "id": "node-wf11-parse-clockify",
      "name": "Parse Clockify Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3180,
        600
      ]
    },
    {
      "parameters": {
        "url": "https://www.googleapis.com/calendar/v3/freeBusy",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.access_token }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ timeMin: $json.today + 'T00:00:00Z', timeMax: $json.today + 'T23:59:59Z', items: [{ id: $json.google_calendar_id }] }) }}",
        "options": {
          "timeout": 15000
        }
      },
      "id": "node-wf11-check-calendar",
      "name": "Check Google Calendar OOO",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3400,
        600
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Evaluate schedule status \u2014 stricter source wins (SC-06a).\nconst calResult = $input.first().json;\nconst calId = $json.google_calendar_id;\nlet calendar_available = true;\nlet on_leave_calendar = false;\n\nif (calResult.error || !calResult.calendars) {\n  calendar_available = false;\n} else {\n  const cal = calResult.calendars[calId];\n  on_leave_calendar = cal && cal.busy && cal.busy.length > 0;\n}\n\nconst clockify_available = $json.clockify_available;\nconst on_leave_clockify = $json.on_leave_clockify;\n\nlet is_scheduled = true;\nlet source = '';\n\nif (!clockify_available && !calendar_available) {\n  // Both unavailable \u2014 fail safe, do not contact (SC-18 / F-05.5)\n  is_scheduled = false;\n  source = 'both_unavailable';\n} else if (!clockify_available) {\n  is_scheduled = !on_leave_calendar;\n  source = 'calendar_only';\n} else if (!calendar_available) {\n  is_scheduled = !on_leave_clockify;\n  source = 'clockify_only';\n} else {\n  // Both available \u2014 stricter wins\n  is_scheduled = !on_leave_clockify && !on_leave_calendar;\n  source = 'clockify+calendar';\n}\n\nreturn [{ json: { ...$json, is_scheduled, schedule_source: source } }];"
      },
      "id": "node-wf11-evaluate-schedule",
      "name": "Evaluate Schedule Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3620,
        600
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-wf11-both-unavailable",
              "leftValue": "={{ $json.schedule_source }}",
              "rightValue": "both_unavailable",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-wf11-handle-both-unavailable",
      "name": "Handle Both Unavailable",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        3840,
        600
      ]
    },
    {
      "parameters": {
