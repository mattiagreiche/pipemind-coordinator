        "rawContentType": "application/json"
      }
    },
    {
      "id": "log-outreach-offer",
      "name": "Log Outreach (Offer)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        5000,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "loY6OMgbNA9Cm4d8",
          "name": "Postgres account"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO pipemind.outreach_log (discord_id, outreach_type, outreach_date) VALUES ($1, 'time_log_offer', CURRENT_DATE) ON CONFLICT (discord_id, outreach_type, outreach_date) DO NOTHING;",
        "options": {
          "queryReplacement": "={{ [ $('Build Draft or Route').item.json.discord_id ] }}"
        }
      }
    },
    {
      "id": "save-message-id",
      "name": "Save Message ID to Draft",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        4500,
        300
      ],
      "continueOnFail": true,
      "credentials": {
        "postgres": {
          "id": "loY6OMgbNA9Cm4d8",
          "name": "Postgres account"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE pipemind.approval_drafts SET discord_message_id = $1 WHERE draft_id = $2::uuid;",
        "options": {
          "queryReplacement": "={{ [ $json.id, $('Create Approval Draft').item.json.draft_id ] }}"
        }
      }
    },
    {
      "id": "if-draft-dm-ok",
      "name": "If Draft DM OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        4400,
        300
      ],
