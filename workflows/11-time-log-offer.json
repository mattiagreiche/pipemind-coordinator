      "name": "Send Info DM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4000,
        100
      ],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "={{ `https://discord.com/api/v10/channels/${$json.id}/messages` }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bot ' + $env.DISCORD_BOT_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "body": "={{ JSON.stringify({ content: $('Build Draft or Route').item.json.info_message }) }}",
        "rawContentType": "application/json"
      }
    },
    {
      "id": "log-outreach-info",
      "name": "Log Outreach (Info)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        4250,
        100
      ],
      "credentials": {
        "postgres": {
          "id": "loY6OMgbNA9Cm4d8",
          "name": "Postgres account"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO pipemind.outreach_log (discord_id, outreach_type, outreach_date) VALUES ($1, 'time_log_offer', CURRENT_DATE) ON CONFLICT (discord_id, outreach_type, outreach_date) DO NOTHING;",
        "options": {
          "queryReplacement": "={{ [ $('Build Draft or Route').item.json.discord_id ] }}"
        }
      }
    },
    {
      "id": "open-offer-dm",
      "name": "Open Offer DM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3750,
        300
      ],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "https://discord.com/api/v10/users/@me/channels",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bot ' + $env.DISCORD_BOT_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "body": "={{ JSON.stringify({ recipient_id: $json.discord_id }) }}",
        "rawContentType": "application/json"
      }
    },
    {
      "id": "create-approval-draft",
      "continueOnFail": true,
      "name": "Create Approval Draft",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        4000,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "loY6OMgbNA9Cm4d8",
          "name": "Postgres account"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO pipemind.approval_drafts (feature_tag, content_type, draft_text, boundary_audit_passed, approver_discord_id, discord_channel_id, context_json) VALUES ('F-07', 'time_entry', $1, TRUE, $2, $3, $4::jsonb) RETURNING draft_id, discord_channel_id;",
        "options": {
          "queryReplacement": "={{ [ $('Build Draft or Route').item.json.draft_text, $('Build Draft or Route').item.json.discord_id, $('Open Offer DM').item.json.id, JSON.stringify({ draft_hours: $('Build Draft or Route').item.json.draft_hours, feature_area: $('Build Draft or Route').item.json.feature_area }) ] }}"
        }
      }
    },
    {
      "id": "send-draft-dm",
      "name": "Send Draft DM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4250,
        300
      ],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "={{ `https://discord.com/api/v10/channels/${$('Create Approval Draft').item.json.discord_channel_id}/messages` }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bot ' + $env.DISCORD_BOT_TOKEN }}"
            }
          ]
        },
