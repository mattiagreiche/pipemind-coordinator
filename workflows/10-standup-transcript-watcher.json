      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "url": "={{ $env.WHISPER_BASE_URL }}/healthz",
        "options": {
          "timeout": 10000
        }
      },
      "id": "node-wf10-check-whisper",
      "name": "Check Whisper Availability",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3180,
        600
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-wf10-whisper-ok",
              "leftValue": "={{ $json.error !== undefined }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-wf10-route-whisper-ok",
      "name": "Whisper Unavailable?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        3400,
        600
      ]
    },
    {
      "parameters": {
        "jsCode": "// Whisper unavailable \u2014 set empty result to continue to mark-processed step.\nconst fileData = $node['Route by File Class'].json;\nreturn [{ json: { ...fileData, updates: [], unattributed_notes: [], parse_quality: 'whisper_unavailable', skip_wf09: true } }];"
      },
      "id": "node-wf10-whisper-unavailable-skip",
      "name": "Mark Whisper Skip Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3620,
        480
      ]
    },
    {
      "parameters": {
        "url": "=https://www.googleapis.com/drive/v3/files/{{ $node['Route by File Class'].json.id }}?alt=media",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $node['Route by File Class'].json.access_token }}"
            }
          ]
        },
        "options": {
          "timeout": 120000,
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "node-wf10-download-audio",
      "name": "Download Audio File",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3620,
        700
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "url": "={{ $env.WHISPER_BASE_URL }}/asr",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "name": "audio_file",
              "parameterType": "formBinaryData",
              "inputDataFieldName": "data"
            },
            {
              "name": "task",
              "value": "transcribe"
            },
            {
              "name": "language",
              "value": "en"
            }
          ]
        },
        "options": {
          "timeout": 300000
        }
      },
      "id": "node-wf10-transcribe-whisper",
      "name": "Transcribe via Whisper",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3840,
