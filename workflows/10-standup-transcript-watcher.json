{
  "name": "10 \u2014 Standup Transcript Watcher (F-04)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "*/15 * * * *"
            }
          ]
        }
      },
      "id": "node-wf10-cron",
      "name": "Cron Trigger \u2014 Every 15 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Load roster.yml \u2014 extract active team members and roster names.\nconst fs = require('fs');\nconst yaml = require('js-yaml');\nconst path = process.env.ROSTER_CONFIG_PATH || '/data/roster.yml';\nlet roster;\ntry {\n  roster = yaml.load(fs.readFileSync(path, 'utf8'));\n} catch (e) {\n  throw new Error('Standup Watcher: cannot load roster.yml: ' + e.message);\n}\nconst activeTeam = (roster.team || []).filter(m => m.active !== false);\nconst rosterNames = activeTeam.map(m => m.name).concat([roster.team_lead ? roster.team_lead.name : '']);\nreturn [{\n  json: {\n    team: activeTeam,\n    team_lead_channel_id: roster.team_lead_channel_id,\n    roster_names: rosterNames.filter(Boolean)\n  }\n}];"
      },
      "id": "node-wf10-load-roster",
      "name": "Load Roster",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Verify required env vars.\nconst required = ['DRIVE_FOLDER_ID', 'GOOGLE_CLIENT_ID', 'GOOGLE_CLIENT_SECRET', 'GOOGLE_REFRESH_TOKEN', 'OLLAMA_BASE_URL'];\nconst missing = required.filter(k => !process.env[k] || process.env[k].trim() === '');\nif (missing.length > 0) {\n  throw new Error('FATAL: Standup Watcher missing env vars: ' + missing.join(', '));\n}\nreturn [{ json: $json }];"
      },
      "id": "node-wf10-check-env",
      "name": "Check Env Vars",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://oauth2.googleapis.com/token",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "client_id": "={{ $env.GOOGLE_CLIENT_ID }}",
          "client_secret": "={{ $env.GOOGLE_CLIENT_SECRET }}",
          "refresh_token": "={{ $env.GOOGLE_REFRESH_TOKEN }}",
          "grant_type": "refresh_token"
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "node-wf10-refresh-token",
      "name": "Refresh Google Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Extract access token and carry roster data forward.\nconst tokenResult = $input.first().json;\nconst rosterData = $node['Load Roster'].json;\nif (!tokenResult.access_token) {\n  throw new Error('Standup Watcher: Google token refresh failed: ' + JSON.stringify(tokenResult.error));\n}\nreturn [{\n  json: {\n    access_token: tokenResult.access_token,\n    team: rosterData.team,\n    team_lead_channel_id: rosterData.team_lead_channel_id,\n    roster_names: rosterData.roster_names\n  }\n}];"
      },
      "id": "node-wf10-extract-token",
      "name": "Extract Google Access Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        980,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT value_json FROM project_memory WHERE key = 'standup_drive_last_check_timestamp' LIMIT 1",
        "options": {}
      },
      "id": "node-wf10-read-timestamp",
      "name": "Read Drive Poll Timestamp",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1200,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "Postgres \u2014 Coordination Agent"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT value_json FROM project_memory WHERE key = 'standup_processed_file_ids' LIMIT 1",
        "options": {}
      },
      "id": "node-wf10-read-processed-ids",
      "name": "Read Processed File IDs",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1420,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "Postgres \u2014 Coordination Agent"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Prepare last check timestamp and carry all context forward.\nconst tsRow = $node['Read Drive Poll Timestamp'].json;\nconst processedRow = $node['Read Processed File IDs'].json;\nconst accessToken = $node['Extract Google Access Token'].json.access_token;\nconst team = $node['Extract Google Access Token'].json.team;\nconst teamLeadChannelId = $node['Extract Google Access Token'].json.team_lead_channel_id;\nconst rosterNames = $node['Extract Google Access Token'].json.roster_names;\n\nconst lastCheckTs = (tsRow && tsRow.value_json)\n  ? (typeof tsRow.value_json === 'string' ? tsRow.value_json.replace(/^\"|\"$/g, '') : tsRow.value_json)\n  : '2000-01-01T00:00:00Z';\n\nconst processedIds = (processedRow && processedRow.value_json)\n  ? (Array.isArray(processedRow.value_json) ? processedRow.value_json : JSON.parse(processedRow.value_json))\n  : [];\n\nreturn [{\n  json: {\n    access_token: accessToken,\n    team,\n    team_lead_channel_id: teamLeadChannelId,\n    roster_names: rosterNames,\n    last_check_timestamp: lastCheckTs,\n    processed_ids: processedIds\n  }\n}];"
      },
      "id": "node-wf10-prepare-query",
      "name": "Prepare Drive Query Parameters",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1640,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://www.googleapis.com/drive/v3/files",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.access_token }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "q",
              "value": "='{{ $env.DRIVE_FOLDER_ID }}' in parents and modifiedTime > '{{ $json.last_check_timestamp }}' and trashed=false"
            },
            {
              "name": "fields",
              "value": "files(id,name,mimeType,modifiedTime,size)"
            },
            {
              "name": "orderBy",
              "value": "modifiedTime asc"
            },
            {
              "name": "pageSize",
              "value": "50"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "node-wf10-query-drive",
      "name": "Query Drive for New Files",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1860,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO project_memory (key, value_json)\nVALUES ('standup_drive_last_check_timestamp', $1::jsonb)\nON CONFLICT (key) DO UPDATE SET value_json = EXCLUDED.value_json, updated_at = now()",
        "additionalFields": {
          "queryBatching": "independently",
          "queryReplacement": "={{ JSON.stringify(new Date().toISOString()) }}"
        },
        "options": {}
      },
      "id": "node-wf10-update-timestamp",
      "name": "Update Drive Poll Timestamp",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2080,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "Postgres \u2014 Coordination Agent"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-wf10-drive-error",
              "leftValue": "={{ $node['Query Drive for New Files'].json.error !== undefined }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-wf10-handle-drive-failure",
      "name": "Handle Drive API Failure",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2300,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://discord.com/api/v10/channels/{{ $node['Prepare Drive Query Parameters'].json.team_lead_channel_id }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bot {{ $env.DISCORD_BOT_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "content": "Standup watcher: Google Drive API unavailable. Will retry in 15 minutes."
        },
        "options": {}
      },
      "id": "node-wf10-post-drive-failure",
      "name": "Post Drive Failure Notice",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2520,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Filter to unprocessed files; classify by type.\nconst driveResult = $node['Query Drive for New Files'].json;\nconst processedIds = $node['Prepare Drive Query Parameters'].json.processed_ids || [];\nconst files = driveResult.files || [];\n\nconst supported_text = ['text/plain', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];\nconst supported_audio = ['audio/mpeg', 'audio/mp4', 'audio/wav', 'audio/x-wav', 'audio/x-m4a'];\n\nconst unprocessed = files.filter(f => !processedIds.includes(f.id));\n\nreturn unprocessed.map(f => {\n  let file_class = 'unsupported';\n  if (supported_text.includes(f.mimeType) || f.name.match(/\\.(txt|docx)$/i)) file_class = 'text';\n  else if (supported_audio.includes(f.mimeType) || f.name.match(/\\.(mp3|m4a|wav)$/i)) file_class = 'audio';\n  return {\n    json: {\n      ...f,\n      file_class,\n      access_token: $node['Prepare Drive Query Parameters'].json.access_token,\n      team: $node['Prepare Drive Query Parameters'].json.team,\n      team_lead_channel_id: $node['Prepare Drive Query Parameters'].json.team_lead_channel_id,\n      roster_names: $node['Prepare Drive Query Parameters'].json.roster_names,\n      processed_ids: processedIds,\n      today: new Date().toISOString().slice(0, 10)\n    }\n  };\n});"
      },
      "id": "node-wf10-filter-files",
      "name": "Filter to Unprocessed Files",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2520,
        400
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "node-wf10-for-each-file",
      "name": "For Each File",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        2740,
        400
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "sw-wf10-text",
                    "leftValue": "={{ $json.file_class }}",
                    "rightValue": "text",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "text"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "sw-wf10-audio",
                    "leftValue": "={{ $json.file_class }}",
                    "rightValue": "audio",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "audio"
            }
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "node-wf10-route-file-class",
      "name": "Route by File Class",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        2960,
        400
      ]
    },
    {
      "parameters": {
        "url": "=https://www.googleapis.com/drive/v3/files/{{ $json.id }}?alt=media",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.access_token }}"
            }
          ]
        },
        "options": {
          "timeout": 60000,
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "node-wf10-download-text",
      "name": "Download Text File Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3180,
        200
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Extract raw text \u2014 handle plain text vs docx.\n// For docx: attempt mammoth extraction. For plain text: use body directly.\nconst fileData = $node['Route by File Class'].json;\nconst downloadResult = $input.first().json;\n\nif (downloadResult.error) {\n  return [{ json: { ...fileData, raw_text: '', download_error: true } }];\n}\n\nlet rawText = '';\nif (fileData.mimeType === 'application/vnd.openxmlformats-officedocument.wordprocessingml.document') {\n  try {\n    const mammoth = require('mammoth');\n    const body = typeof downloadResult === 'string' ? downloadResult : JSON.stringify(downloadResult);\n    const buf = Buffer.from(body, 'base64');\n    const result = await mammoth.extractRawText({ buffer: buf });\n    rawText = result.value || '';\n  } catch (e) {\n    // Mammoth failed \u2014 treat as unsupported\n    return [{ json: { ...fileData, raw_text: '', file_class: 'unsupported', download_error: false } }];\n  }\n} else {\n  // Plain text\n  rawText = typeof downloadResult === 'string' ? downloadResult : JSON.stringify(downloadResult);\n}\n\nreturn [{ json: { ...fileData, raw_text: rawText, download_error: false } }];"
      },
      "id": "node-wf10-extract-text",
      "name": "Extract Raw Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3400,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "\n// Sanitize file name to prevent prompt injection\nconst rawFileName = $json.name || 'unknown';\nconst safeFileName = rawFileName.replace(/[^a-zA-Z0-9._-]/g, '_').substring(0, 100);\n\n// Assemble Ollama parse request for standup text.\n// System prompt is verbatim from the planner \u2014 do not alter.\nconst data = $json;\nconst rawText = data.raw_text || '';\nconst today = data.today || new Date().toISOString().slice(0, 10);\n\nconst systemPrompt = `You are a project coordination assistant parsing a standup transcript. Extract project-level progress updates.\n\nMANDATORY RULES:\n1. Do NOT attribute any update to a named individual. Convert all speaker-attributed content to work-area level.\n   Example: \"Alice said the auth feature is done\" \u2192 { \"area\": \"auth feature\", \"status_hint\": \"completed\", \"progress_note\": \"Authentication feature completed.\" }\n2. If you cannot determine which work area an update belongs to, place it in unattributed_notes as a project-level sentence.\n3. Do NOT fabricate content. Extract only what is explicitly stated.\n4. Do NOT include any person's name in any output field.\n5. Output ONLY valid JSON \u2014 no prose, no markdown fences:\n{\n  \"updates\": [\n    {\n      \"area\": \"<work area or feature name>\",\n      \"status_hint\": \"<progressing|blocked|completed|unknown>\",\n      \"progress_note\": \"<one sentence, project-level, no names>\",\n      \"has_blocker\": <true|false>,\n      \"blocker_note\": \"<project-level blocker description or null>\"\n    }\n  ],\n  \"unattributed_notes\": [\"<project-level note>\"],\n  \"parse_quality\": \"<good|partial|poor>\"\n}\nIf the transcript is garbled, partial, or unattributable (F-04.3), set parse_quality to \"partial\" or \"poor\" and extract only what is reliable. Do not fabricate.`;\n\nconst userMessage = `Standup transcript (date: ${today}, file: ${safeFileName}):\\n\\n<transcript>\\n${rawText}\\n</transcript>\\n\\nExtract project-level updates. No individual names in output.`;\n\nconst llmRequest = {\n  model: 'llama3',\n  messages: [\n    { role: 'system', content: systemPrompt },\n    { role: 'user', content: userMessage }\n  ],\n  temperature: 0.1,\n  stream: false\n};\n\nreturn [{ json: { ...data, llm_request: llmRequest } }];"
      },
      "id": "node-wf10-build-parse-prompt",
      "name": "Build Standup Parse Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3620,
        200
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.OLLAMA_BASE_URL }}/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify($json.llm_request) }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "node-wf10-call-ollama-parse",
      "name": "Parse Standup Text \u2014 Call Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3840,
        200
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Parse Ollama response for standup text extraction.\nconst result = $input.first().json;\nconst data = $node['Build Standup Parse Prompt'].json;\n\nlet updates = [];\nlet unattributedNotes = [];\nlet parseQuality = 'failed';\n\nif (!result.error && result.choices && result.choices[0]) {\n  try {\n    let raw = result.choices[0].message.content.trim();\n    raw = raw.replace(/^```json\\s*/i, '').replace(/\\s*```$/, '');\n    const parsed = JSON.parse(raw);\n    updates = parsed.updates || [];\n    unattributedNotes = parsed.unattributed_notes || [];\n    parseQuality = parsed.parse_quality || 'good';\n  } catch (e) {\n    updates = [];\n    unattributedNotes = ['Transcript parse failed \u2014 JSON parse error.'];\n    parseQuality = 'failed';\n  }\n} else {\n  unattributedNotes = ['Transcript parse failed \u2014 LLM error.'];\n}\n\nreturn [{\n  json: {\n    ...data,\n    updates,\n    unattributed_notes: unattributedNotes,\n    parse_quality: parseQuality\n  }\n}];"
      },
      "id": "node-wf10-parse-ollama-response",
      "name": "Parse Standup LLM Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4060,
        200
      ]
    },
    {
      "parameters": {
        "url": "=https://discord.com/api/v10/channels/{{ $json.team_lead_channel_id }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bot {{ $env.DISCORD_BOT_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "content": "=Standup watcher: audio file '{{ $json.name }}' skipped \u2014 Whisper transcription service unavailable ({{ $env.WHISPER_BASE_URL }}/healthz). Resolve the service and re-drop the file or re-trigger manually."
        },
        "options": {}
      },
      "id": "node-wf10-whisper-unavailable-notice",
      "name": "Post Whisper Unavailable Notice",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3180,
