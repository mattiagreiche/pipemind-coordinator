    {
      "parameters": {
        "jsCode": "// Write standup-heard records.\n// raw_text is used ONLY here for roster name matching. It is never written to Postgres.\n// Only discord_ids (not names, not content) are stored in standup_heard_*.\nconst data = $json;\nconst rawText = data.raw_text || '';\nconst rosterTeam = data.team || [];\nconst today = data.today || new Date().toISOString().slice(0, 10);\nconst heardIds = [];\n\nfor (const member of rosterTeam) {\n  const firstName = member.name.split(' ')[0];\n  const re = new RegExp('\\\\b' + firstName.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&') + '\\\\b', 'i');\n  if (re.test(rawText)) {\n    heardIds.push(member.discord_id);\n  }\n}\n\nreturn [{ json: { ...data, today, heard_ids: heardIds } }];"
