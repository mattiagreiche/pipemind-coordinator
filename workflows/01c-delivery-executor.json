    {
      "id": "fetch-draft",
      "name": "Fetch Approved Draft",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [250, 300],
      "credentials": { "postgres": { "id": "pipemindPostgres", "name": "Pipemind Postgres" } },
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT draft_id, content_type,\n       COALESCE(edited_text, draft_text) AS final_text,\n       edited_text,\n       context_json,\n       approver_discord_id,\n       discord_channel_id\nFROM pipemind.approval_drafts\nWHERE draft_id = $1::uuid AND status = 'approved' AND boundary_audit_passed = TRUE;",
        "additionalFields": {
          "queryParams": "={{ [ $('Delivery Input').item.json.draft_id ] }}"
        }
      }
    },
