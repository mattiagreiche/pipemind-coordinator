        "headerParameters": {
          "parameters": [
            { "name": "X-Api-Key",    "value": "={{ $env.CLOCKIFY_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ start: $json.start_iso, end: $json.end_iso, description: $json.description }) }}"
