      "name": "Validate QA Channel",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 250],
      "parameters": {
        "jsCode": "const draft = $('Fetch Approved Draft').item.json;\nconst stored = String(draft.context_json?.client_channel_id || '');\nconst expected = String($env.CLIENT_CHANNEL_ID || '');\nif (!stored || !expected || stored !== expected) {\n  throw new Error('Delivery aborted: context_json.client_channel_id does not match CLIENT_CHANNEL_ID. Possible channel manipulation.');\n}\nreturn [{ json: draft }];"
      }
