    {
      "id": "parse-time-entry",
      "name": "Parse Time Entry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1750, 800],
      "parameters": {
        "jsCode": "const draft = $('Fetch Approved Draft').item.json;\nconst clockifyUserId = $json.clockify_user_id;\nif (!clockifyUserId) {\n  throw new Error('F-07 delivery aborted: no clockify_user_id in roster for approver_discord_id ' + draft.approver_discord_id);\n}\n\nconst contextJson = typeof draft.context_json === 'object' ? draft.context_json : {};\n\n// CRIT-03: validate draft_hours -- reject 0, negative, non-finite, >16h values\nconst rawDraftHours = Number(contextJson.draft_hours);\nconst draftHours = (isFinite(rawDraftHours) && rawDraftHours > 0 && rawDraftHours <= 16) ? rawDraftHours : 8;\n\n// MED-03: strip non-printable chars and clamp before it reaches Clockify description\nconst featureArea = String(contextJson.feature_area || 'General').replace(/[^\\x20-\\x7E]/g, '').slice(0, 80) || 'General';\n\n// CRIT-02: cap edited hours at 16h (same as draftHours max)\nlet finalHours = draftHours;\nconst editedText = String(draft.edited_text || '').trim();\nconst hourMatch = editedText.match(/^edit\\s+(\\d+(?:\\.\\d+)?)\\s*h(?:ours?)?/i);\nif (hourMatch) {\n  const parsed = parseFloat(hourMatch[1]);\n  if (!isNaN(parsed) && parsed > 0 && parsed <= 16) {\n    finalHours = parsed;\n  }\n}\n\n// Compute start/end based on EOD_TIME env var (e.g., '17:00' or '17:00:00')\nconst eodTime = String($env.EOD_TIME || '17:00');\nconst [eodHour, eodMin] = eodTime.split(':').map(n => parseInt(n, 10));\nconst today = new Date();\nconst endTime  = new Date(Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), today.getUTCDate(), eodHour || 17, eodMin || 0, 0));\nconst startTime = new Date(endTime.getTime() - finalHours * 3_600_000);\n\n// CRIT-02: cross-day guard -- reject entries that would cross midnight\nif (startTime.getUTCDate() !== endTime.getUTCDate()) {\n  throw new Error('F-07 delivery aborted: ' + finalHours + 'h entry would cross midnight (end=' + endTime.toISOString() + '). Reduce hours or check EOD_TIME config.');\n}\n\nreturn [{ json: {\n  draft_id:            draft.draft_id,\n  discord_channel_id:  draft.discord_channel_id,\n  clockify_user_id:    clockifyUserId,\n  feature_area:        featureArea,\n  final_hours:         finalHours,\n  description:         featureArea !== 'General' ? 'Work on the ' + featureArea + ' feature' : 'General development work',\n  start_iso:           startTime.toISOString(),\n  end_iso:             endTime.toISOString()\n} }];"
      }
    },
    {
      "id": "write-clockify-entry",
      "name": "Write Clockify Entry",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
