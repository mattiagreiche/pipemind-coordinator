    {
      "parameters": {
        "jsCode": "// Read cursor and prepare for Discord API call.\nconst cursorRow = $input.first().json;\nconst dmData = $node['Extract DM Channel ID'].json;\nconst lastMsgId = cursorRow && cursorRow.value_json ? cursorRow.value_json : null;\nconst afterParam = lastMsgId ? `&after=${lastMsgId}` : '';\nreturn [{ json: {\n  ...dmData,\n  last_msg_id: lastMsgId,\n  after_param: afterParam\n}}];"
      },
      "id": "node-prepare-fetch",
      "name": "Prepare Fetch Parameters",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1860,
        400
      ]
    },
    {
      "parameters": {
        "url": "=https://discord.com/api/v10/channels/{{ $json.dm_channel_id }}/messages?limit=10{{ $json.after_param }}",
        "sendHeaders": true,
        "headerParameters": [
          {
            "name": "Authorization",
            "value": "=Bot {{ $env.DISCORD_BOT_TOKEN }}"
          }
        ],
        "options": {}
      },
      "id": "node-fetch-dm-messages",
      "name": "Fetch Unprocessed DM Messages",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2080,
        400
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Filter to messages from the developer (not from bot).\n// Bot messages are identified by matching bot_discord_id stored in project_memory.\n// For safety: filter to messages where author.id == developer_discord_id.\nconst messages = $input.first().json;\nconst devData = $node['Prepare Fetch Parameters'].json;\n\nif (!Array.isArray(messages) || messages.length === 0) {\n  return [];\n}\n\nconst devId = devData.developer_discord_id;\nconst devMessages = messages.filter(m => m.author && m.author.id === devId);\n\nif (devMessages.length === 0) return [];\n\nconst highestId = devMessages.map(m => m.id).reduce((a, b) => a > b ? a : b, devMessages[0].id);\n\nreturn devMessages.map(m => ({\n  json: {\n    message_id: m.id,\n    message_content: m.content,\n    dm_channel_id: devData.dm_channel_id,\n    developer_discord_id: devData.developer_discord_id,\n    developer_name: devData.developer_name,\n    roster_names: devData.roster_names,\n    cursor_key: devData.cursor_key,\n    highest_id: highestId\n  }\n}));"
      },
      "id": "node-filter-dev-messages",
      "name": "Filter Developer Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2300,
        400
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO project_memory (key, value_json) VALUES ($1, $2::jsonb) ON CONFLICT (key) DO UPDATE SET value_json = EXCLUDED.value_json, updated_at = now()",
        "additionalFields": {
          "queryBatching": "independently",
          "queryReplacement": "={{ $json.cursor_key }},={{ JSON.stringify($json.highest_id) }}"
        },
        "options": {}
      },
      "id": "node-persist-cursor",
      "name": "Persist DM Cursor",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2520,
        400
