    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO project_memory (key, value_json) VALUES ($1, $2::jsonb) ON CONFLICT (key) DO UPDATE SET value_json = EXCLUDED.value_json, updated_at = now()",
        "additionalFields": {
          "queryBatching": "independently",
          "queryReplacement": "={{ 'action_log_dev_dm_' + $json.message_id }},={{ JSON.stringify({ action: 'dev_query_answered', developer_discord_id: $json.developer_discord_id, timestamp: new Date().toISOString() }) }}"
        },
        "options": {}
      },
      "id": "node-qa-handler-log-action",
