    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "node-for-each-message",
      "name": "For Each Message",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        2740,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// Classify message: !mute, !unmute, !explain, or Q&A.\nconst content = ($json.message_content || '').trim();\nconst lower = content.toLowerCase();\nlet type;\nif (lower === '!mute') {\n  type = 'mute';\n} else if (lower === '!unmute') {\n  type = 'unmute';\n} else if (lower.startsWith('!explain')) {\n  type = 'explain';\n} else {\n  type = 'qa';\n}\nreturn [{ json: { ...$json, message_type: type } }];"
      },
      "id": "node-detect-message-type",
      "name": "Detect Message Type",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2960,
        400
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "sw-mute",
                    "leftValue": "={{ $json.message_type }}",
                    "rightValue": "mute",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "mute"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "sw-unmute",
                    "leftValue": "={{ $json.message_type }}",
                    "rightValue": "unmute",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "unmute"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "sw-explain",
                    "leftValue": "={{ $json.message_type }}",
                    "rightValue": "explain",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "explain"
            }
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "node-route-message-type",
      "name": "Route Message Type",
