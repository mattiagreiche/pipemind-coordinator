{
  "name": "07 \u2014 Developer DM Listener (F-17)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "*/2 * * * *"
            }
          ]
        }
      },
      "id": "node-cron-trigger",
      "name": "Cron Trigger \u2014 Every 2 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        100,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// Load roster.yml. Extract active team members with discord_id and name.\n// NO approval gate for F-17 \u2014 this is intentional per spec.\nconst fs = require('fs');\nconst yaml = require('js-yaml');\nconst path = process.env.ROSTER_CONFIG_PATH || '/data/roster.yml';\nlet roster;\ntry {\n  roster = yaml.load(fs.readFileSync(path, 'utf8'));\n} catch (e) {\n  throw new Error('Dev DM Listener: cannot load roster.yml: ' + e.message);\n}\nconst activeTeam = (roster.team || []).filter(m => m.active !== false);\nreturn [{\n  json: {\n    active_team: activeTeam,\n    roster_names: activeTeam.map(m => m.name).concat([roster.team_lead.name])\n  }\n}];"
      },
      "id": "node-load-roster",
      "name": "Load Roster",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// Expand active_team into individual items for SplitInBatches.\nconst rosterData = $json;\nreturn rosterData.active_team.map(m => ({\n  json: {\n    developer_discord_id: m.discord_id,\n    developer_name: m.name,\n    roster_names: rosterData.roster_names\n  }\n}));"
      },
      "id": "node-expand-developers",
      "name": "Expand Developers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        400
      ]
    },
    {
