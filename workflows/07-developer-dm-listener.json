        "sendBody": true,
        "contentType": "json",
        "body": {
          "recipient_id": "={{ $json.developer_discord_id }}"
        },
        "options": {}
      },
      "id": "node-get-or-open-dm-channel",
      "name": "Get or Open DM Channel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        980,
        400
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Cache the DM channel ID in project_memory for reuse.\nconst dmResult = $input.first().json;\nconst devData = $node['For Each Developer (Split)'].json;\n\nif (dmResult.error || !dmResult.id) {\n  // Cannot open DM \u2014 log and skip this developer\n  return [{ json: { skip: true, reason: 'Cannot open DM: ' + (dmResult.error || 'no id'), developer_discord_id: devData.developer_discord_id } }];\n}\n\nreturn [{\n  json: {\n    skip: false,\n    dm_channel_id: dmResult.id,\n    developer_discord_id: devData.developer_discord_id,\n    developer_name: devData.developer_name,\n    roster_names: devData.roster_names,\n    cursor_key: 'dev_dm_last_msg_' + devData.developer_discord_id\n  }\n}];"
      },
      "id": "node-extract-dm-channel",
      "name": "Extract DM Channel ID",
      "type": "n8n-nodes-base.code",
