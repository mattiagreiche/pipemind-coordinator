    {
      "parameters": {
        "url": "https://discord.com/api/v10/users/@me/channels",
        "sendHeaders": true,
        "headerParameters": [
          {
            "name": "Authorization",
            "value": "=Bot {{ $env.DISCORD_BOT_TOKEN }}"
          },
          {
            "name": "Content-Type",
            "value": "application/json"
          }
