    {
      "parameters": {
        "jsCode": "// Transparency handler (SC-13): explain what the agent did.\n// Only return information relevant to this developer's own data.\nconst content = ($json.message_content || '').trim();\nconst subject = content.replace(/^!explain\\s*/i, '').trim();\nreturn [{ json: { ...$json, explain_subject: subject } }];"
      },
      "id": "node-explain-handler-parse",
      "name": "Explain Handler \u2014 Parse Subject",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3400,
        480
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT key, value_json FROM project_memory WHERE key LIKE 'action_log_%'",
        "options": {}
      },
      "id": "node-explain-handler-fetch-logs",
      "name": "Explain Handler \u2014 Fetch Logs",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        3620,
        480
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "Postgres \u2014 Coordination Agent"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Build explanation using only this developer's own data (SC-13).\n// Third-party individual data must not be exposed.\nconst devData = $node['Explain Handler \u2014 Parse Subject'].json;\nconst subject = devData.explain_subject.toLowerCase();\nconst devId = devData.developer_discord_id;\nconst logs = $input.all();\n\n// Filter to logs involving this developer only\nconst matching = logs.filter(item => {\n  const v = typeof item.json.value_json === 'string' ? JSON.parse(item.json.value_json) : item.json.value_json;\n  const keyMatches = (item.json.key || '').toLowerCase().includes(subject);\n  const bodyMatches = JSON.stringify(v).toLowerCase().includes(subject);\n  // Only include if it's a dev_dm log for this developer OR a general log (no individual_id that differs)\n  const isThisDev = v.developer_discord_id && v.developer_discord_id === devId;\n  return (keyMatches || bodyMatches) && isThisDev;\n});\n\nlet explanation;\nif (matching.length === 0) {\n  explanation = `No recent actions found matching '${devData.explain_subject}'. I have not logged any action with that description recently.`;\n} else {\n  const lines = matching.map(item => {\n    const v = typeof item.json.value_json === 'string' ? JSON.parse(item.json.value_json) : item.json.value_json;\n    return `- Action: ${v.action || 'unknown'} | At: ${v.timestamp || 'n/a'}`;\n  });\n  explanation = `Here is what I did related to '${devData.explain_subject}':\\n${lines.join('\\n')}\\n\\nI do not include information about other team members in this explanation. (SC-13)`;\n}\n\nreturn [{ json: { explanation, dm_channel_id: devData.dm_channel_id } }];"
      },
      "id": "node-explain-handler-compose",
      "name": "Explain Handler \u2014 Compose Explanation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3840,
        480
      ]
    },
    {
      "parameters": {
        "url": "=https://discord.com/api/v10/channels/{{ $json.dm_channel_id }}/messages",
        "sendHeaders": true,
        "headerParameters": [
          {
            "name": "Authorization",
            "value": "=Bot {{ $env.DISCORD_BOT_TOKEN }}"
          },
          {
            "name": "Content-Type",
            "value": "application/json"
          }
        ],
        "sendBody": true,
        "contentType": "json",
        "body": {
          "content": "={{ $json.explanation }}"
        },
        "options": {}
      },
      "id": "node-explain-handler-reply",
      "name": "Explain Handler \u2014 Post Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4060,
        480
      ]
    },
    {
      "parameters": {
        "jsCode": "// Q&A Handler: build Ollama request.\n// System prompt is verbatim from the planner. No approval gate (F-17).\nconst data = $json;\n\nconst systemPrompt = `You are a project coordination assistant helping a team member understand their project. Answer questions with project-level context.\n\nMANDATORY RULES:\n1. Do not name or attribute information to any individual team member other than the person asking. The person asking may receive information about their own work area.\n2. Do not disclose what other team members are working on in an attributed way.\n3. If the question asks who specifically is assigned to a work area, provide the work-area context without naming individuals (per SC-03).\n4. Do not produce productivity scores, commit counts attributed to individuals, or hours attributed to individuals.\n5. If you do not know the answer, say so honestly. Do not fabricate.\n6. Keep the response concise \u2014 under 200 words.\n\nThe person asking is: ${data.developer_name}. You may use their name and reference their own work area specifically.`;\n\nconst userMessage = `Developer question: ${data.message_content}\\nProject context: No stored project context available.`;\n\nconst llmRequest = {\n  model: 'llama3',\n  messages: [\n    { role: 'system', content: systemPrompt },\n    { role: 'user', content: userMessage }\n  ],\n  temperature: 0.3,\n  stream: false\n};\n\nreturn [{ json: { ...data, llm_request: llmRequest } }];"
      },
      "id": "node-qa-handler-build-prompt",
      "name": "Q&A Handler \u2014 Build LLM Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3400,
        620
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.OLLAMA_BASE_URL }}/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": [
          {
            "name": "Content-Type",
            "value": "application/json"
          }
        ],
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify($json.llm_request) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "node-qa-handler-call-ollama",
      "name": "Q&A Handler \u2014 Call Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3620,
        620
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Extract answer and apply privacy validation.\n// Redact other roster members' names. Allow requesting developer's own name through.\nconst result = $input.first().json;\nconst data = $node['Q&A Handler \u2014 Build LLM Prompt'].json;\nconst rosterNames = data.roster_names || [];\nconst developerName = data.developer_name;\n\nlet answerText = \"I'm temporarily unable to answer \u2014 the reasoning service is offline. Please try again shortly.\";\nif (!result.error && result.choices && result.choices[0]) {\n  answerText = result.choices[0].message.content || answerText;\n}\n\n// Privacy validation: redact other names, keep developer's own name\nfor (const name of rosterNames) {\n  if (!name || name === developerName) continue; // Keep requester's own name\n  const escapedName = name.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n  const regex = new RegExp(`\\\\b${escapedName}\\\\b`, 'gi');\n  answerText = answerText.replace(regex, '[team member]');\n}\n\nreturn [{ json: {\n  reply_text: answerText,\n  dm_channel_id: data.dm_channel_id,\n  developer_discord_id: data.developer_discord_id,\n  message_id: data.message_id\n}}];"
      },
      "id": "node-qa-handler-privacy-validate",
      "name": "Q&A Handler \u2014 Privacy Validation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3840,
        620
      ]
    },
    {
      "parameters": {
        "url": "=https://discord.com/api/v10/channels/{{ $json.dm_channel_id }}/messages",
        "sendHeaders": true,
        "headerParameters": [
          {
            "name": "Authorization",
            "value": "=Bot {{ $env.DISCORD_BOT_TOKEN }}"
          },
          {
            "name": "Content-Type",
            "value": "application/json"
          }
        ],
        "sendBody": true,
        "contentType": "json",
        "body": {
