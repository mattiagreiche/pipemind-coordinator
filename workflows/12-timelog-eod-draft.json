    {
      "parameters": {
        "jsCode": "// Build final draft content \u2014 use LLM output or fallback.\nconst llmResponse = $input.first().json;\nconst data = $node['Assemble Time Entry Draft Text'].json;\nconst today = data.today;\nconst eodHour = data.eod_hour;\nconst eodMin = data.eod_min;\n\nlet description = 'Time entry for ' + today + ' \u2014 please edit to reflect your actual work.';\nif (llmResponse.choices && llmResponse.choices[0]) {\n  try {\n    const parsed = JSON.parse(\n      llmResponse.choices[0].message.content.trim()\n        .replace(/^```json\\s*/i, '').replace(/\\s*```$/, '')\n    );\n    if (parsed.description) description = parsed.description;\n  } catch (e) { /* use fallback */ }\n}\n\nconst draftText = [\n  `**Time Entry Draft \u2014 ${today}**`,\n  '',\n  `**Description:** ${description}`,\n  `**Start:** ${today} 09:00 UTC`,\n  `**End:** ${today} ${eodHour}:${eodMin} UTC`,\n  '',\n  'Reply `!approve <draft_id>` to log this entry, `!edit <draft_id> <new description>` to change the description, or `!reject <draft_id>` to skip.'\n].join('\\n');\n\nreturn [{\n  json: {\n    ...data,\n    description,\n    start_iso: today + 'T09:00:00Z',\n    end_iso: today + 'T' + eodHour + ':' + eodMin + ':00Z',\n    draft_text: draftText\n  }\n}];"
