    {
      "parameters": {
        "jsCode": "// Assemble time entry draft \u2014 LLM for description.\n// System prompt is verbatim from the planner \u2014 do not alter.\nconst data = $json;\nconst today = data.today;\nconst projectPicture = data.project_picture;\nconst heardIds = data.heard_ids || [];\nconst discordId = data.discord_id;\n\n// Determine EOD hour/minute\nconst eodTime = process.env.EOD_TIME || '17:00';\nconst eodParts = eodTime.split(':');\nconst eodHour = eodParts[0].padStart(2, '0');\nconst eodMin = (eodParts[1] || '00').padStart(2, '0');\n\n// Build standup context \u2014 project-level feature context only (no raw standup, no other developer names)\nlet standupContext = 'No standup data available for today. Generic placeholder needed.';\nif (projectPicture && projectPicture.features && heardIds.includes(discordId)) {\n  const recentProgress = projectPicture.features\n    .filter(f => f.recent_progress)\n    .map(f => f.recent_progress)\n    .join(' ');\n  if (recentProgress) standupContext = recentProgress;\n}\n\nconst systemPrompt = `You are a project coordination assistant helping a developer log their time at the end of the day.\n\nMANDATORY RULES:\n1. Draft a short, honest time entry description (1-2 sentences) for the developer's day.\n2. Use only project-level feature context provided \u2014 do not invent tasks.\n3. Do not name any other team member.\n4. If no specific work context is available, produce a generic, honest placeholder. The developer will edit it.\n5. Phrase the description in first-person work terms, not in a status-report style.\n6. Output ONLY valid JSON \u2014 no prose, no fences:\n   { \"description\": \"<time entry description>\" }`;\n\nconst userMessage = `Developer work area context (project-level only): ${standupContext}\\nToday's date: ${today}\\nDraft a probable time entry description for this developer's day.`;\n\nconst llmRequest = {\n  model: 'llama3',\n  messages: [\n    { role: 'system', content: systemPrompt },\n    { role: 'user', content: userMessage }\n  ],\n  temperature: 0.2,\n  stream: false\n};\n\nreturn [{ json: { ...data, llm_request: llmRequest, eod_hour: eodHour, eod_min: eodMin } }];"
      },
