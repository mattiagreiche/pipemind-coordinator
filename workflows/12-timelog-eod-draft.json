        "jsCode": "const result = $input.first().json;\nlet clockify_check_failed = false;\nlet already_logged = false;\n\nif (result.error || !Array.isArray(result)) {\n  clockify_check_failed = true;\n} else {\n  already_logged = result.length > 0;\n}\nreturn [{ json: { ...$json, clockify_check_failed, already_logged } }];"
