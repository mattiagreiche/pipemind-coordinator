# =============================================================================
# Pipemind Coordination Agent — Environment Template
# =============================================================================
# RULES (SC-08):
#   - Every value below MUST be an op://CoordinationAgent/... reference.
#   - Real values MUST NEVER appear in this file or the repository.
#   - Validate with: grep -v "^#" .env | grep -v "op://" | grep "="
#     (must return empty output)
#
# HOW TO USE:
#   1. Set OP_SERVICE_ACCOUNT_TOKEN on the host:
#        export OP_SERVICE_ACCOUNT_TOKEN="<your-1password-service-account-token>"
#      This is the ONE value that is NOT an op:// reference and is NOT stored in
#      this file. It must be exported in the shell before running op run.
#
#   2. Start the stack:
#        op run --env-file=.env -- docker compose up -d
#
# 1Password vault: CoordinationAgent
# Item naming convention: CoordinationAgent/<item-name>/[field]
# =============================================================================


# -----------------------------------------------------------------------------
# Postgres credentials
# -----------------------------------------------------------------------------
POSTGRES_USER=op://CoordinationAgent/postgres/username
POSTGRES_PASSWORD=op://CoordinationAgent/postgres/password
POSTGRES_DB=op://CoordinationAgent/postgres/database


# -----------------------------------------------------------------------------
# n8n — workflow orchestrator
# -----------------------------------------------------------------------------
N8N_ENCRYPTION_KEY=op://CoordinationAgent/n8n/encryption_key
N8N_BASIC_AUTH_USER=op://CoordinationAgent/n8n/basic_auth_user
N8N_BASIC_AUTH_PASSWORD=op://CoordinationAgent/n8n/basic_auth_password


# -----------------------------------------------------------------------------
# Required config values (non-secret but must be present — agent fails visibly
# if any of these are absent or empty at startup)
# -----------------------------------------------------------------------------
DRIVE_FOLDER_ID=op://CoordinationAgent/config/drive_folder_id
CLIENT_EMAIL=op://CoordinationAgent/config/client_email
EOD_TIME=op://CoordinationAgent/config/eod_time
REPORT_DAY_TIME=op://CoordinationAgent/config/report_day_time
# Path inside the n8n container where roster.yml is mounted (see docker-compose.yml).
# This is a non-secret path constant. It is hardcoded in docker-compose.yml rather
# than here so that this file contains only op:// references and plain-value grep
# validation passes cleanly.
# ROSTER_CONFIG_PATH is set directly in docker-compose.yml as: /data/roster.yml


# -----------------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=op://CoordinationAgent/discord/bot_token


# -----------------------------------------------------------------------------
# Clockify
# -----------------------------------------------------------------------------
CLOCKIFY_API_KEY=op://CoordinationAgent/clockify/api_key
CLOCKIFY_WORKSPACE_ID=op://CoordinationAgent/clockify/workspace_id


# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
GITHUB_TOKEN=op://CoordinationAgent/github/token
GITHUB_REPO=op://CoordinationAgent/github/repo


# -----------------------------------------------------------------------------
# Jira
# -----------------------------------------------------------------------------
JIRA_EMAIL=op://CoordinationAgent/jira/email
JIRA_API_TOKEN=op://CoordinationAgent/jira/api_token
JIRA_SITE_URL=op://CoordinationAgent/jira/site_url
JIRA_PROJECT_KEY=op://CoordinationAgent/jira/project_key


# -----------------------------------------------------------------------------
# Google OAuth (Drive, Gmail, Calendar)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=op://CoordinationAgent/google-oauth/client_id
GOOGLE_CLIENT_SECRET=op://CoordinationAgent/google-oauth/client_secret
GOOGLE_REFRESH_TOKEN=op://CoordinationAgent/google-oauth/refresh_token


# -----------------------------------------------------------------------------
# Langfuse — LLM observability (uncomment if langfuse service is enabled)
# -----------------------------------------------------------------------------
# LANGFUSE_SECRET_KEY=op://CoordinationAgent/langfuse/secret_key
# LANGFUSE_PUBLIC_KEY=op://CoordinationAgent/langfuse/public_key
# LANGFUSE_NEXTAUTH_SECRET=op://CoordinationAgent/langfuse/nextauth_secret
# LANGFUSE_SALT=op://CoordinationAgent/langfuse/salt
