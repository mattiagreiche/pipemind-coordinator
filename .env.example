# ---------------------------------------------------------------
# BOOTSTRAP — run once before docker compose up:
#
#   op signin
#   op run --env-file=.env -- docker compose up -d
#
# DO NOT put OP_SERVICE_ACCOUNT_TOKEN in this file.
# Export it in your shell or CI environment:
#   export OP_SERVICE_ACCOUNT_TOKEN=<your token>
# ---------------------------------------------------------------

# ---------------------------------------------------------------
# Secrets — all resolved at runtime via 1Password CLI (SC-08)
# Vault: CoordinationAgent
# ---------------------------------------------------------------

# Infrastructure
POSTGRES_PASSWORD=op://CoordinationAgent/postgres/password
N8N_ENCRYPTION_KEY=op://CoordinationAgent/n8n/encryption-key

# n8n UI auth
N8N_BASIC_AUTH_USER=op://CoordinationAgent/n8n/basic-auth-user
N8N_BASIC_AUTH_PASSWORD=op://CoordinationAgent/n8n/basic-auth-password

# Discord
DISCORD_BOT_TOKEN=op://CoordinationAgent/discord/bot-token

# Google (Drive + Gmail + Calendar — même OAuth app, mêmes credentials)
GOOGLE_CLIENT_ID=op://CoordinationAgent/google/client-id
GOOGLE_CLIENT_SECRET=op://CoordinationAgent/google/client-secret
GOOGLE_REFRESH_TOKEN=op://CoordinationAgent/google/refresh-token

# GitHub
GITHUB_TOKEN=op://CoordinationAgent/github/token
GITHUB_OWNER=
GITHUB_REPO=

# Jira
JIRA_BASE_URL=op://CoordinationAgent/jira/base-url
JIRA_TOKEN=op://CoordinationAgent/jira/token
JIRA_PROJECT_KEY=
# JIRA_AUTH: base64(email:api_token) — workflows may use this format for Basic Auth headers
JIRA_AUTH=op://CoordinationAgent/jira/basic-auth-b64

# Trello (workflow 07 supplementary signal — used in place of Jira)
TRELLO_KEY=op://CoordinationAgent/trello/key
TRELLO_TOKEN=op://CoordinationAgent/trello/token
TRELLO_BOARD_ID=

# Anthropic API (hosted LLM — replaces Ollama, SC-11)
ANTHROPIC_API_KEY=op://CoordinationAgent/anthropic/api-key

# Clockify
CLOCKIFY_API_KEY=op://CoordinationAgent/clockify/api-key
# Required by workflows 10, 11, 12, 01b, 01c — agent fails visibly if absent
CLOCKIFY_WORKSPACE_ID=op://CoordinationAgent/clockify/workspace-id

# ---------------------------------------------------------------
# Deployment config (not secrets — set directly)
# ---------------------------------------------------------------

# n8n workflow IDs — fill in after importing workflows into n8n
# (Settings → Variables is Enterprise-only; these are passed as env vars instead)
F08_WORKFLOW_ID=
F03_WORKFLOW_ID=
F01_WORKFLOW_ID=
F14_WORKFLOW_ID=
DELIVERY_EXECUTOR_WORKFLOW_ID=

# Required at startup — agent fails visibly if any of these are empty (CLAUDE.md)
DRIVE_FOLDER_ID=
CLIENT_EMAIL=
EOD_TIME=17:00
REPORT_DAY_TIME=Friday 17:00

# n8n public URL (used for webhook registration)
WEBHOOK_URL=http://localhost:5678

# Discord channel IDs (numeric IDs — right-click channel > Copy ID in Discord)
# TL_CHANNEL_ID: the restricted Team Lead approval channel — used by every workflow
# that posts drafts or alerts for TL review (00, 01, 03, 04, 05, 06, 10, 11, 12)
TL_CHANNEL_ID=
# CLIENT_CHANNEL_ID: used by workflows 01c, 05, 06 for client-facing Discord channel
CLIENT_CHANNEL_ID=

# LLM model — Anthropic model ID, SC-11
LLM_MODEL=claude-haiku-4-5-20251001

# ---------------------------------------------------------------
# Reference values (informational — hardcoded in docker-compose.yml)
# ---------------------------------------------------------------
# POSTGRES_HOST=postgres        (Docker service name; not configurable)
# POSTGRES_PORT=5432            (default; not configurable)
# POSTGRES_DB=n8n               (hardcoded in docker-compose.yml)
# POSTGRES_USER=n8n             (hardcoded in docker-compose.yml)
# OLLAMA_BASE_URL=http://ollama:11434/v1  (LLM_BASE_URL in compose; internal network only)
# N8N_PORT=5678                 (hardcoded in docker-compose.yml; exposed on 127.0.0.1:5678)

# ---------------------------------------------------------------
# STARTUP VALIDATION GAP — workflow 00 does NOT validate env vars
# ---------------------------------------------------------------
# Workflow 00 (00-startup-config-validation.json) validates roster.json structure
# only. It does NOT check that DRIVE_FOLDER_ID, CLIENT_EMAIL, EOD_TIME, or
# REPORT_DAY_TIME are set. If these are empty, the corresponding workflows (F-01
# client reports, F-15 client welcome, time-log triggers) will fail at runtime
# without a clear startup alert. Ensure these four values are filled above before
# starting the stack.
